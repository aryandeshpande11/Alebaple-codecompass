# IBM watsonx.ai Configuration
# Copy this file to .env and fill in your actual credentials

# IBM watsonx.ai API Credentials
WATSONX_API_KEY=your_api_key_here
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Model Configuration
WATSONX_MODEL_ID=ibm/granite-13b-chat-v2

# Generation Parameters
MAX_NEW_TOKENS=1024
MIN_NEW_TOKENS=50
TEMPERATURE=0.7
TOP_P=0.9
TOP_K=50
REPETITION_PENALTY=1.1

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY=1.0

# Timeout Configuration (seconds)
REQUEST_TIMEOUT=60

# Mock Mode (set to false when using real credentials)
USE_MOCK_RESPONSES=true

# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Get your IBM watsonx.ai credentials from: https://cloud.ibm.com/
# 3. Create a watsonx.ai project and get the project ID
# 4. Generate an API key with appropriate permissions
# 5. Update the values above with your actual credentials
# 6. Set USE_MOCK_RESPONSES=false to use real API calls
# 7. Never commit the .env file to version control!